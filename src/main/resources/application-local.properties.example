# Copy this file to application-local.properties (git-ignored) and fill in your values.
# Run with: mvn spring-boot:run -Dspring-boot.run.profiles=local

# --- Database (local PostgreSQL) ---
DB_URL=jdbc:postgresql://localhost:5432/typingtutor
DB_USERNAME=postgres
DB_PASSWORD=your-postgres-password

# --- JWT ---
JWT_SECRET=replace-with-a-32-plus-char-random-secret

# --- Email (optional) ---
MAIL_HOST=smtp.gmail.com
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# --- AI lesson generation (optional) ---
AI_API_KEY=your-anthropic-api-key
